# ─── Build Stage ───────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app
COPY front_next/package.json front_next/package-lock.json ./
RUN npm ci

COPY front_next/ ./
RUN npm run build

# ─── Runtime Stage ─────────────────────────────────────────
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY front_next/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
